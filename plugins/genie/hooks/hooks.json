{
  "description": "Genie lifecycle hooks for Codex",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/smart-install.js",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/first-run-check.cjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/session-context.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|apply_patch|SendMessage|mcp__genie__.*",
        "hooks": [
          {
            "type": "command",
            "command": "genie hook dispatch",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/validate-wish.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "genie hook dispatch --runtime codex",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/validate-wish.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/session-context.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/scripts/validate-completion.cjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
