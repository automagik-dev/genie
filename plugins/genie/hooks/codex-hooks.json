{
  "description": "Minimal Genie lifecycle hooks for Codex: bounded session context, deterministic local guardrails, and permission-scoped Omni approval.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/session-context.cjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\session-context.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/dispatch-runtime.cjs\" codex",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\dispatch-runtime.cjs\" codex",
            "timeout": 15
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/dispatch-runtime.cjs\" codex",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\dispatch-runtime.cjs\" codex",
            "timeout": 125
          }
        ]
      }
    ]
  }
}
