{
  "description": "Minimal Genie lifecycle hooks for Codex: bounded session context, deterministic local guardrails, and permission-scoped Omni approval.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/session-context.cjs\"",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\session-context.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/dispatch-runtime.cjs\" codex PreToolUse --launcher-contract genie-codex-dispatch-v1 --launcher-sha256 17da5aa8cd81406562a9259b6fa818dc0166328dc5cbf26b5d05c599ca54c726",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\dispatch-runtime.cjs\" codex PreToolUse --launcher-contract genie-codex-dispatch-v1 --launcher-sha256 17da5aa8cd81406562a9259b6fa818dc0166328dc5cbf26b5d05c599ca54c726",
            "timeout": 15
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/dispatch-runtime.cjs\" codex PermissionRequest --launcher-contract genie-codex-dispatch-v1 --launcher-sha256 17da5aa8cd81406562a9259b6fa818dc0166328dc5cbf26b5d05c599ca54c726",
            "commandWindows": "node \"%PLUGIN_ROOT%\\scripts\\dispatch-runtime.cjs\" codex PermissionRequest --launcher-contract genie-codex-dispatch-v1 --launcher-sha256 17da5aa8cd81406562a9259b6fa818dc0166328dc5cbf26b5d05c599ca54c726",
            "timeout": 125
          }
        ]
      }
    ]
  }
}
