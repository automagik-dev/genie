{
  "description": "Genie lifecycle hooks for Claude Code",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/smart-install.js", "timeout": 60 },
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/first-run-check.cjs", "timeout": 5 },
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-context.cjs", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Write|Edit|SendMessage",
        "hooks": [{ "type": "command", "command": "genie hook dispatch --runtime claude", "timeout": 120 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/validate-wish.cjs", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/validate-wish.cjs", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/validate-completion.cjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
