set -e

remote="$1"
while read local_ref local_oid remote_ref remote_oid; do
  if echo "$remote_ref" | grep -qE 'refs/heads/(main|master)$'; then
    echo "BLOCKED: push to $remote_ref is forbidden."
    echo "Main is production — human merges the rolling PR."
    exit 1
  fi
done

# Strip git env inherited from the push so tests that spawn git in tmpdirs work
unset GIT_DIR GIT_WORK_TREE GIT_COMMON_DIR GIT_INDEX_FILE GIT_OBJECT_DIRECTORY GIT_QUARANTINE_PATH GIT_PREFIX GIT_INTERNAL_GETTEXT_SH_SCHEME

# Serialize `bun test` invocations across the host. The repo's PG-integration
# tests share a single test pgserve daemon (port 20900 by design — see
# src/lib/test-setup.ts). When multiple `bun test` processes race against the
# same daemon (another agent's pre-push hook, an interactive `bun test` in a
# sibling tmux pane, a CI shard run on the same host, etc.) the failure
# profile becomes nondeterministic: 5 fails, 9 fails, 22 fails, 438 fails are
# all reproducible run-to-run with no source changes — observed directly
# while diagnosing this. The race is on the shared template DB clone path,
# resource limits inside pgserve, and process-level `GENIE_TEST_DB_NAME`
# being set per-run from concurrent setupTestDatabase() callers.
#
# `flock` on a host-wide sentinel file makes hooks line up instead of fight.
# The wait blocks the offending push; the lock is held only for the duration
# of `bun run check` (~2-3 minutes), then released on EXIT.
LOCK_FILE=/tmp/genie-bun-test.lock
if command -v flock >/dev/null 2>&1; then
  echo "▶ pre-push: acquiring host-wide bun-test lock ($LOCK_FILE) — waits if another bun test is in flight..."
  exec 9>"$LOCK_FILE"
  flock 9
  trap 'flock -u 9' EXIT
fi
bun run check
