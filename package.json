{
  "name": "@automagik/genie",
  "version": "4.260327.5",
  "description": "Collaborative terminal toolkit for human + AI workflows",
  "type": "module",
  "bin": {
    "genie": "./dist/genie.js"
  },
  "scripts": {
    "prepare": "test \"$CI\" = true || husky",
    "version": "bun run scripts/version.ts",
    "build": "bun build src/genie.ts --outdir dist --target bun --minify-syntax --minify-whitespace --external bun --external pgserve && chmod +x dist/*.js",
    "build:plugin": "node scripts/build.js",
    "sync": "node scripts/sync.js",
    "build-and-sync": "npm run build:plugin && npm run sync",
    "prepack": "bun run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "dead-code": "bunx knip",
    "check": "bun run typecheck && bun run lint && bun run dead-code && bun test"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1",
    "nats": "^2.29.3",
    "pgserve": "^1.1.6",
    "postgres": "^3.4.8",
    "uuid": "^11.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "typescript": "^5.8.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/automagik-dev/genie.git"
  },
  "openclaw": {
    "extensions": ["./plugins/genie/index.ts"]
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "trustedDependencies": ["@biomejs/biome", "bun"]
}
